---
import { parts, pets, type Locale, type Pet } from "@jojo-codex-pet/catalog";
import { localize, route, ui } from "../lib/i18n";

interface Props { locale: Locale; pet: Pet }
const { locale, pet } = Astro.props;
const copy = ui[locale];
const name = localize(pet.name, locale);
const isReview = pet.status === "pilot-review" || pet.status === "wave-review";
const part = parts.find((item) => item.number === pet.part)!;
const partTitle = localize(part.title, locale);
const wave = pet.part <= 3 ? 1 : pet.part <= 6 ? 2 : 3;
const displayImage = pet.image?.replace(/\.png$/, "-card.webp");
const imageAlt = locale === "en"
  ? `${name}, Part ${pet.part} pixel Codex pet`
  : `${name}，JoJo 第 ${pet.part} 部像素 Codex 宠物`;
const related = [pet.ownerId, ...(pet.pairIds ?? [])].flatMap((id) => {
  if (!id) return [];
  const match = pets.find((item) => item.id === id);
  return match ? [match] : [];
});
const siteOrigin = "https://pixelstand.pet";
const packageUrl = pet.packagePath ? `${siteOrigin}${pet.packagePath}` : undefined;
const openInCodexUrl = packageUrl ? `codex://pets/install?${new URLSearchParams({
  name: pet.name.en,
  imageUrl: `${packageUrl}/spritesheet.webp`,
  description: `Unofficial JoJo-themed Codex pet: ${pet.name.en}`,
  spriteVersionNumber: "2"
}).toString()}` : undefined;
const installCommands = packageUrl ? [
  { label: "Bash · macOS / Linux", command: `curl -fsSL ${siteOrigin}/install.sh | bash -s -- ${pet.id}` },
  { label: "PowerShell · Windows", command: `& ([scriptblock]::Create((irm ${siteOrigin}/install.ps1))) ${pet.id}` },
  { label: "npx · cross-platform", command: `npx --yes --package=github:geoqiao/jojo-codex-pet jojo-codex-pet ${pet.id}` }
] : [];
const content = locale === "en" ? {
  identity: "Catalog identity",
  relationship: "Stand relationship",
  ability: "Ability modes inside this pet",
  palette: "Locked signature palette",
  source: "Source",
  install: "Install this pet",
  pending: "This pet is not installable yet. Its complete v2 animation and QA package must pass before installation is enabled.",
  reviewPending: "Engineering QA is complete. Public installation remains disabled until final owner animation approval.",
  ready: "The complete v2 atlas passed deterministic validation, three blind direction reviews, and independent visual QA. Every method below installs only this pet.",
  overview: `${name} is the ${copy.role[pet.role].toLowerCase()} ${copy.type[pet.type].toLowerCase()} entry for Part ${pet.part}, ${partTitle}, in the 36-pet headline roster.`,
  released: `${name} is released as a validated Codex Pet V2 package from Wave ${wave}.`,
  review: `${name}'s complete V2 atlas passed engineering QA and is waiting for final owner animation approval before release.`,
  planned: `${name} is assigned to Wave ${wave}. Its base art, complete V2 animation, package validation, and visual QA are not published yet.`,
  views: "Public page views",
  openInCodex: "Open in Codex",
  download: "Package files",
  copy: "Copy",
  copied: "Copied"
} : {
  identity: "目录身份",
  relationship: "替身关系",
  ability: "包含在本宠物中的能力模式",
  palette: "锁定标志配色",
  source: "来源",
  install: "安装这只宠物",
  pending: "这只宠物暂不可安装。完整 V2 动画和 QA 包通过后才会启用安装。",
  reviewPending: "工程 QA 已完成；公开安装仍保持关闭，等待站长最终动画审核通过。",
  ready: "完整 V2 图集已通过确定性校验、三次盲测方向审核和独立视觉 QA。以下每种方式都只安装当前这只宠物。",
  overview: `${name}是 36 只首发名单中 JoJo 第 ${pet.part} 部《${partTitle}》的${copy.role[pet.role]}${copy.type[pet.type]}宠物。`,
  released: `${name}已在第 ${wave} 波次作为通过验证的 Codex Pet V2 包发布。`,
  review: `${name}的完整 V2 图集已通过工程 QA，正在等待站长最终动画审核后发布。`,
  planned: `${name}属于第 ${wave} 波次，基础造型、完整 V2 动画、宠物包验证与视觉 QA 尚未发布。`,
  views: "公开页面浏览次数",
  openInCodex: "在 Codex 中打开",
  download: "宠物包文件",
  copy: "复制",
  copied: "已复制"
};
---

<div class="detail-grid">
  <div class="detail-art" style={`--accent:${part.accent}`}>
    {displayImage ? (
      <img src={displayImage} alt={imageAlt} width="640" height="640" />
    ) : (
      <div class="planned-sigil" aria-hidden="true"><span>{String(pet.part).padStart(2, "0")}</span><i>{pet.type === "character" ? "C" : "S"}</i></div>
    )}
    <span class="detail-part">PART {String(pet.part).padStart(2, "0")}</span>
  </div>
  <div class="detail-copy">
    <div class="detail-pills"><span class="status-pill" data-status={pet.status}>{copy.status[pet.status]}</span><span class="type-pill">{copy.type[pet.type]}</span></div>
    <h1>{name}</h1>
    <p class="part-title">{localize(part.title, locale)} · {copy.role[pet.role]}</p>
    <p class="pet-overview">{content.overview}</p>
    <p class="status-note">{pet.status === "released" ? content.released : isReview ? content.review : content.planned}</p>
    <dl>
      <div><dt>{content.identity}</dt><dd><code>{pet.id}</code></dd></div>
      <div><dt>{content.views}</dt><dd><span data-view-count={pet.id}>— {copy.view}</span></dd></div>
      {related.length > 0 && (
        <div>
          <dt>{content.relationship}</dt>
          <dd>{related.map((item, index) => <><a href={route(locale, `/pets/${item.id}/`)}>{localize(item.name, locale)}</a>{index < related.length - 1 ? " · " : ""}</>)}</dd>
        </div>
      )}
      {pet.abilityModes && <div><dt>{content.ability}</dt><dd>{pet.abilityModes.map((mode) => localize(mode, locale)).join(" · ")}</dd></div>}
      {pet.palette && <div><dt>{content.palette}</dt><dd class="detail-palette">{pet.palette.map((color) => <span style={`--swatch:${color}`}><i>{color}</i></span>)}</dd></div>}
      <div><dt>{content.source}</dt><dd><a href={pet.source}>geoqiao/jojo-codex-pet ↗</a></dd></div>
    </dl>
    <section class="install-box">
      <h2>{content.install}</h2>
      {pet.status === "released" && packageUrl && openInCodexUrl ? (
        <>
          <p>{content.ready}</p>
          <div class="install-primary">
            <a class="button" href={openInCodexUrl}>{content.openInCodex} ↗</a>
            <a class="package-link" href={`${packageUrl}/pet.json`}>{content.download} ↗</a>
          </div>
          <div class="command-list">
            {installCommands.map(({ label, command }) => (
              <div class="command-row">
                <span>{label}</span>
                <code>{command}</code>
                <button type="button" data-copy-command={command} data-copy-label={content.copy} data-copied-label={content.copied}>{content.copy}</button>
              </div>
            ))}
          </div>
        </>
      ) : (
        <><p>{isReview ? content.reviewPending : content.pending}</p><button class="button" type="button" disabled aria-disabled="true">{isReview ? copy.reviewNotInstallable : copy.notInstallable}</button></>
      )}
    </section>
  </div>
</div>

<style>
  .detail-grid {
    display: grid;
    grid-template-columns: minmax(320px, 0.8fr) minmax(0, 1fr);
    min-height: 720px;
    border: 3px solid var(--ink);
    background: var(--paper-bright);
    box-shadow: var(--shadow);
  }

  .detail-art {
    position: relative;
    display: grid;
    min-height: 680px;
    place-items: center;
    overflow: hidden;
    background:
      linear-gradient(140deg, rgb(255 255 255 / 38%) 0 14%, transparent 14% 68%, rgb(23 19 30 / 18%) 68%),
      var(--accent);
    border-right: 3px solid var(--ink);
  }

  .detail-art::before {
    position: absolute;
    width: 78%;
    aspect-ratio: 1;
    content: "";
    border: 34px solid rgb(255 255 255 / 24%);
    border-radius: 50%;
    rotate: -14deg;
  }

  .detail-art img {
    position: relative;
    z-index: 1;
    width: 88%;
    height: 620px;
    object-fit: contain;
    image-rendering: pixelated;
    filter: drop-shadow(8px 9px 0 rgb(23 19 30 / 42%));
  }

  .detail-part {
    position: absolute;
    z-index: 2;
    top: 24px;
    left: 24px;
    padding: 7px 11px;
    color: var(--paper-bright);
    background: var(--ink);
    font-size: 0.68rem;
    font-weight: 850;
    letter-spacing: 0.13em;
  }

  .planned-sigil {
    position: relative;
    z-index: 1;
    display: grid;
    width: 250px;
    height: 310px;
    place-items: center;
    color: var(--paper-bright);
    background: var(--ink);
    clip-path: polygon(16% 0, 86% 7%, 100% 52%, 74% 100%, 7% 90%, 0 35%);
  }

  .planned-sigil span {
    font-family: "Bodoni Moda Variable", Georgia, serif;
    font-size: 8rem;
    font-weight: 900;
  }

  .planned-sigil i {
    position: absolute;
    right: 32px;
    bottom: 26px;
    color: var(--acid);
    font-style: normal;
    font-weight: 900;
  }

  .detail-copy { padding: clamp(30px, 5vw, 70px); }
  .detail-pills { display: flex; gap: 8px; }

  h1 {
    margin: 28px 0 24px;
    font-family: "Bodoni Moda Variable", Georgia, serif;
    font-size: clamp(4rem, 9vw, 9rem);
    letter-spacing: -0.07em;
    line-height: 0.92;
  }

  .part-title {
    margin: 0;
    color: var(--muted);
    font-size: 0.78rem;
    font-weight: 850;
    letter-spacing: 0.09em;
    text-transform: uppercase;
  }

  .pet-overview {
    max-width: 66ch;
    margin: 18px 0 0;
    color: var(--muted);
    font-size: 1rem;
    font-weight: 620;
    line-height: 1.65;
  }

  .status-note {
    margin: 30px 0;
    padding: 14px 16px;
    border: 2px solid var(--ink);
    background: var(--acid);
    font-weight: 720;
  }

  dl { margin: 0; }

  dl > div {
    display: grid;
    grid-template-columns: 180px 1fr;
    gap: 18px;
    padding: 14px 0;
    border-top: 2px solid var(--ink);
  }

  dt {
    font-size: 0.68rem;
    font-weight: 850;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  dd { margin: 0; font-weight: 620; }
  dd a { text-underline-offset: 4px; }
  code { font-size: 0.78rem; }

  .detail-palette { display: flex; flex-wrap: wrap; gap: 8px; }

  .detail-palette span {
    display: grid;
    width: 86px;
    height: 42px;
    align-items: end;
    padding: 4px;
    border: 2px solid var(--ink);
    background: var(--swatch);
  }

  .detail-palette i {
    padding: 2px 4px;
    color: var(--paper-bright);
    background: var(--ink);
    font-size: 0.55rem;
    font-style: normal;
  }

  .install-box {
    margin-top: 32px;
    padding: 22px;
    color: var(--paper-bright);
    background: var(--ink);
  }

  .install-box h2 {
    margin: 0;
    font-family: "Bodoni Moda Variable", Georgia, serif;
    font-size: 2.4rem;
  }

  .install-box p { max-width: 58ch; line-height: 1.55; }

  .install-primary {
    display: flex;
    flex-wrap: wrap;
    gap: 18px;
    align-items: center;
    margin-top: 20px;
  }

  .package-link {
    color: var(--paper-bright);
    font-size: 0.72rem;
    font-weight: 820;
    letter-spacing: 0.06em;
    text-underline-offset: 4px;
    text-transform: uppercase;
  }

  .command-list {
    display: grid;
    gap: 10px;
    margin-top: 26px;
  }

  .command-row {
    display: grid;
    grid-template-columns: 150px minmax(0, 1fr) auto;
    gap: 12px;
    align-items: center;
    padding: 12px;
    border: 1px solid rgb(255 255 255 / 35%);
  }

  .command-row > span {
    color: var(--acid);
    font-size: 0.65rem;
    font-weight: 850;
    letter-spacing: 0.07em;
    text-transform: uppercase;
  }

  .command-row code {
    min-width: 0;
    overflow-x: auto;
    color: var(--paper-bright);
    font-size: 0.68rem;
    white-space: nowrap;
  }

  .command-row button {
    min-height: 34px;
    padding: 6px 10px;
    border: 1px solid var(--paper-bright);
    color: var(--paper-bright);
    background: transparent;
    font-size: 0.62rem;
    font-weight: 850;
    cursor: pointer;
  }

  @media (max-width: 900px) {
    .detail-grid { grid-template-columns: 1fr; }
    .detail-art { min-height: 500px; border-right: 0; border-bottom: 3px solid var(--ink); }
    .detail-art img { height: 470px; }
  }

  @media (max-width: 600px) {
    dl > div { grid-template-columns: 1fr; gap: 5px; }
    .detail-art { min-height: 410px; }
    .detail-art img { height: 390px; }
    .command-row { grid-template-columns: 1fr auto; }
    .command-row code { grid-column: 1 / -1; grid-row: 2; }
  }
</style>

<script>
  for (const button of document.querySelectorAll<HTMLButtonElement>("[data-copy-command]")) {
    button.addEventListener("click", async () => {
      const command = button.dataset.copyCommand;
      if (!command) return;
      await navigator.clipboard.writeText(command);
      button.textContent = button.dataset.copiedLabel ?? "Copied";
      window.setTimeout(() => { button.textContent = button.dataset.copyLabel ?? "Copy"; }, 1400);
    });
  }
</script>
