---
import { parts, type Locale, type Pet } from "@jojo-codex-pet/catalog";
import BaseLayout from "../../layouts/BaseLayout.astro";
import PetDetailContent from "../PetDetailContent.astro";
import ViewCounts from "../ViewCounts.astro";
import { localize, route, ui } from "../../lib/i18n";

interface Props { locale: Locale; pet: Pet }
const { locale, pet } = Astro.props;
const copy = ui[locale];
const name = localize(pet.name, locale);
const part = parts.find((item) => item.number === pet.part)!;
const partTitle = localize(part.title, locale);
const statusLabel = copy.status[pet.status];
const content = locale === "en" ? {
  title: `${name} — Part ${pet.part}: ${partTitle} Codex Pet`,
  description: `${name} is the Part ${pet.part} ${copy.role[pet.role].toLowerCase()} ${copy.type[pet.type].toLowerCase()} pet for ${partTitle}. Status: ${statusLabel}.`,
  back: "Back to gallery",
  imageAlt: `${name}, a pixel-art Codex pet from JoJo Part ${pet.part}`
} : {
  title: `${name} — JoJo 第 ${pet.part} 部《${partTitle}》Codex 宠物`,
  description: `${name}是 JoJo 第 ${pet.part} 部《${partTitle}》的${copy.role[pet.role]}${copy.type[pet.type]}宠物，当前状态：${statusLabel}。`,
  back: "返回宠物目录",
  imageAlt: `${name}，JoJo 第 ${pet.part} 部像素 Codex 宠物`
};
const pageUrl = new URL(route(locale, `/pets/${pet.id}/`), Astro.site);
const imageUrl = pet.image ? new URL(pet.image, Astro.site) : new URL("/social/jojo-codex-pet-promo-v1.png", Astro.site);
const structuredData = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  name: content.title,
  description: content.description,
  url: pageUrl.href,
  inLanguage: locale,
  primaryImageOfPage: {
    "@type": "ImageObject",
    url: imageUrl.href
  },
  isPartOf: {
    "@type": "WebSite",
    name: "JoJo Codex Pet",
    url: "https://pixelstand.pet/"
  }
};
---

<BaseLayout
  locale={locale}
  title={content.title}
  description={content.description}
  path={`/pets/${pet.id}/`}
  image={pet.image}
  imageAlt={content.imageAlt}
  structuredData={structuredData}
>
  <div class="shell detail-shell">
    <p class="back-link"><a href={route(locale, "/")}>← {content.back}</a></p>
    <PetDetailContent locale={locale} pet={pet} />
  </div>
  <ViewCounts locale={locale} incrementId={pet.id} />
</BaseLayout>

<style>
  .detail-shell { padding-top: 38px; }

  .back-link {
    margin: 0 0 24px;
    font-size: 0.75rem;
    font-weight: 850;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .back-link a { text-underline-offset: 4px; }

</style>
