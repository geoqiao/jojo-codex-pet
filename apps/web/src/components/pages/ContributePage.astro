---
import type { Locale } from "@jojo-codex-pet/catalog";
import BaseLayout from "../../layouts/BaseLayout.astro";

interface Props { locale: Locale }
const { locale } = Astro.props;
const content = locale === "en" ? {
  title: "Contribute — JoJo Codex Pet",
  description: "Contribution rules for JoJo Codex Pet code, content, and V2 pet packages.",
  eyebrow: "Public repository · submissions open",
  heading: "WAVE 1 PASSED. COMMUNITY OPEN.",
  intro: "Wave 1 passed animation, package-installation, and gallery QA. Pull requests are now open for project improvements and JoJo-only Expansion Pets that meet the complete V2 gate.",
  gate: "Pet submission gate: open",
  allowed: "Project improvements",
  allowedItems: ["Project code", "Accessibility", "English / Chinese copy", "Documentation and validation"],
  later: "Expansion Pets",
  laterItems: ["JoJo-only characters or Stands", "One character or one Stand per package", "Complete V2 animation and QA", "Stable Part-scoped IDs"],
  github: "View the public repository"
} : {
  title: "投稿 — JoJo Codex Pet",
  description: "JoJo Codex Pet 的代码、内容与 V2 宠物包投稿规则。",
  eyebrow: "公开仓库 · 投稿已开放",
  heading: "WAVE 1 已通过，社区投稿开放。",
  intro: "Wave 1 已通过动画、安装包与目录 QA。现在可以提交项目改进，也可以提交满足完整 V2 质量门的 JoJo 限定扩展宠物。",
  gate: "宠物投稿入口：已开放",
  allowed: "项目改进",
  allowedItems: ["项目代码", "无障碍", "中英文文案", "文档与验证"],
  later: "扩展宠物",
  laterItems: ["仅限 JoJo 角色或替身", "每包一个角色或一个替身", "完整 V2 动画与 QA", "篇章稳定 ID"],
  github: "查看公开仓库"
};
---

<BaseLayout locale={locale} title={content.title} description={content.description} path="/contribute/">
  <div class="shell">
    <header class="page-intro">
      <div><p class="eyebrow">{content.eyebrow}</p><h1 class="display">{content.heading}</h1></div>
      <p>{content.intro}</p>
    </header>
    <div class="gate-banner"><span>OPEN</span><strong>{content.gate}</strong></div>
    <div class="contribute-grid">
      <section class="prose-card"><p class="eyebrow">01</p><h2>{content.allowed}</h2><ul>{content.allowedItems.map((item) => <li>{item}</li>)}</ul></section>
      <section class="prose-card"><p class="eyebrow">02</p><h2>{content.later}</h2><ul>{content.laterItems.map((item) => <li>{item}</li>)}</ul></section>
    </div>
    <p class="repository-link"><a class="button" href="https://github.com/geoqiao/jojo-codex-pet">{content.github} ↗</a></p>
  </div>
</BaseLayout>

<style>
  .gate-banner {
    display: flex;
    gap: 24px;
    align-items: center;
    padding: 18px 24px;
    color: var(--paper-bright);
    background: var(--ink);
    border: 3px solid var(--ink);
    box-shadow: 7px 7px 0 var(--coral);
  }

  .gate-banner span {
    padding: 7px 10px;
    color: var(--ink);
    background: var(--coral);
    font-size: 0.68rem;
    font-weight: 900;
    letter-spacing: 0.1em;
  }

  .gate-banner strong {
    font-family: "Bodoni Moda Variable", Georgia, serif;
    font-size: clamp(1.5rem, 4vw, 3rem);
    letter-spacing: -0.03em;
  }

  .contribute-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 28px;
    margin-top: 42px;
  }

  .prose-card h2 {
    margin: 0;
    font-size: clamp(2.7rem, 6vw, 5.2rem);
    line-height: 0.9;
  }

  .prose-card li {
    padding-block: 9px;
    border-bottom: 1px solid var(--ink);
    font-weight: 650;
  }

  .repository-link { margin-top: 38px; }

  @media (max-width: 720px) {
    .contribute-grid { grid-template-columns: 1fr; }
  }
</style>
