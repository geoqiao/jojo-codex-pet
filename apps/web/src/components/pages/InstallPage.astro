---
import { pets, type Locale } from "@jojo-codex-pet/catalog";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { localize } from "../../lib/i18n";

interface Props { locale: Locale }
const { locale } = Astro.props;
const releasedPets = pets.filter((pet) => pet.status === "released" && pet.packagePath);
const releasedPet = releasedPets[0]!;
const siteOrigin = "https://jojo-preview.easytry.shop";
const localePrefix = locale === "zh-CN" ? "/zh-CN" : "";
const packageUrl = `${siteOrigin}${releasedPet.packagePath}`;
const petName = localize(releasedPet.name, locale);
const openInCodexUrl = `codex://pets/install?${new URLSearchParams({
  name: releasedPet.name.en,
  imageUrl: `${packageUrl}/spritesheet.webp`,
  description: `Unofficial JoJo-themed Codex pet: ${releasedPet.name.en}`,
  spriteVersionNumber: "2"
}).toString()}`;

const commands = {
  bash: `curl -fsSL ${siteOrigin}/install.sh | bash -s -- ${releasedPet.id}`,
  powershell: `& ([scriptblock]::Create((irm ${siteOrigin}/install.ps1))) ${releasedPet.id}`,
  npx: `npx --yes --package=github:geoqiao/jojo-codex-pet jojo-codex-pet ${releasedPet.id}`
};

const content = locale === "en" ? {
  title: "Install — JoJo Codex Pet",
  description: "Install validated JoJo Codex Pet v2 companions through official Codex, Bash, PowerShell, or npx flows.",
  eyebrow: "One pet per primary action",
  heading: "INSTALL ONLY WHAT YOU CHOOSE.",
  intro: "Choose any released pet below. Every route installs only the selected Part-scoped pet and never silently adds a Stand Pair or an entire Part.",
  released: "Featured released pet",
  gate: `${petName} is the featured install example.`,
  gateBody: "Its 8 × 11 atlas passed deterministic checks, three blind direction reviews, and independent final visual QA.",
  availableTitle: `${releasedPets.length} validated pets are live`,
  availableNote: "Open any pet to use its Codex deep link or copy its Bash, PowerShell, or npx command.",
  character: "Character",
  stand: "Stand",
  open: "Open in Codex",
  copy: "Copy",
  copied: "Copied",
  methods: [
    ["Open in Codex", "Uses the official Codex pet-install deep link and the hosted v2 spritesheet."],
    ["Bash", "macOS and Linux installer with SHA-256 and manifest validation."],
    ["PowerShell", "Windows installer with the same package integrity checks."],
    ["npx", "Cross-platform Node installer using the stable Part-scoped pet ID."]
  ]
} : {
  title: "安装 — JoJo Codex Pet",
  description: "通过 Codex 官方深链、Bash、PowerShell 或 npx 安装已验证的 JoJo Codex Pet V2。",
  eyebrow: "主操作一次只安装一只",
  heading: "只安装你选中的宠物。",
  intro: "从下方选择任意已发布宠物。每条安装路径只安装当前篇章稳定 ID 对应的宠物，不会暗中附带替身配对或整部合集。",
  released: "推荐安装示例",
  gate: `${petName}是当前安装示例。`,
  gateBody: "其 8 × 11 图集已通过确定性检查、三次方向盲测和独立最终视觉 QA。",
  availableTitle: `${releasedPets.length} 只已验证宠物现已开放`,
  availableNote: "打开任意宠物详情页，即可使用 Codex 深链，或复制 Bash、PowerShell、npx 安装命令。",
  character: "角色",
  stand: "替身",
  open: "在 Codex 中打开",
  copy: "复制",
  copied: "已复制",
  methods: [
    ["在 Codex 中打开", "使用 Codex 官方宠物安装深链与托管的 V2 图集。"],
    ["Bash", "面向 macOS 与 Linux，校验 SHA-256 和宠物清单。"],
    ["PowerShell", "面向 Windows，执行相同的宠物包完整性校验。"],
    ["npx", "使用篇章稳定宠物 ID 的跨平台 Node 安装器。"]
  ]
};
---

<BaseLayout locale={locale} title={content.title} description={content.description} path="/install/">
  <div class="shell">
    <header class="page-intro">
      <div><p class="eyebrow">{content.eyebrow}</p><h1 class="display">{content.heading}</h1></div>
      <p>{content.intro}</p>
    </header>
    <section class="gate-card">
      <span aria-hidden="true">01</span>
      <div><p class="eyebrow">{content.released}</p><h2>{content.gate}</h2><p>{content.gateBody}</p></div>
    </section>
    <section class="released-section" aria-labelledby="released-pets-title">
      <header>
        <h2 id="released-pets-title">{content.availableTitle}</h2>
        <p>{content.availableNote}</p>
      </header>
      <div class="released-grid">
        {releasedPets.map((pet) => (
          <a href={`${localePrefix}/pets/${pet.id}/`}>
            <span>PART {String(pet.part).padStart(2, "0")}</span>
            <strong>{localize(pet.name, locale)}</strong>
            <small>{pet.type === "character" ? content.character : content.stand} ↗</small>
          </a>
        ))}
      </div>
    </section>
    <div class="method-grid">
      {content.methods.map(([name, detail], index) => {
        const command = index === 1 ? commands.bash : index === 2 ? commands.powershell : index === 3 ? commands.npx : undefined;
        return (
          <article>
            <span>0{index + 1}</span>
            <h2>{name}</h2>
            <p>{detail}</p>
            {index === 0 ? (
              <a class="button" href={openInCodexUrl}>{content.open} ↗</a>
            ) : (
              <div class="install-command">
                <code>{command}</code>
                <button class="button" type="button" data-copy-command={command} data-copy-label={content.copy} data-copied-label={content.copied}>{content.copy}</button>
              </div>
            )}
          </article>
        );
      })}
    </div>
  </div>
</BaseLayout>

<script>
  for (const button of document.querySelectorAll<HTMLButtonElement>("[data-copy-command]")) {
    button.addEventListener("click", async () => {
      const command = button.dataset.copyCommand;
      if (!command) return;
      await navigator.clipboard.writeText(command);
      button.textContent = button.dataset.copiedLabel ?? "Copied";
      window.setTimeout(() => { button.textContent = button.dataset.copyLabel ?? "Copy"; }, 1400);
    });
  }
</script>

<style>
  .gate-card {
    display: grid;
    grid-template-columns: minmax(180px, 0.35fr) 1fr;
    overflow: hidden;
    border: 3px solid var(--ink);
    background: var(--acid);
    box-shadow: var(--shadow);
  }

  .gate-card > span {
    display: grid;
    min-height: 280px;
    place-items: center;
    color: var(--paper-bright);
    background: var(--violet);
    border-right: 3px solid var(--ink);
    font-family: "Bodoni Moda Variable", Georgia, serif;
    font-size: 8rem;
    font-weight: 900;
  }

  .gate-card > div { padding: clamp(28px, 5vw, 60px); }

  .gate-card h2 {
    max-width: 18ch;
    margin: 0;
    font-family: "Bodoni Moda Variable", Georgia, serif;
    font-size: clamp(2.6rem, 6vw, 5.8rem);
    letter-spacing: -0.06em;
    line-height: 0.9;
  }

  .gate-card p:last-child { max-width: 65ch; line-height: 1.6; }

  .released-section {
    margin-top: 64px;
  }

  .released-section > header {
    display: grid;
    grid-template-columns: minmax(0, 0.8fr) minmax(280px, 0.5fr);
    gap: 32px;
    align-items: end;
    margin-bottom: 24px;
  }

  .released-section h2 {
    margin: 0;
    font-family: "Bodoni Moda Variable", Georgia, serif;
    font-size: clamp(2.6rem, 5vw, 5.2rem);
    letter-spacing: -0.055em;
    line-height: 0.9;
  }

  .released-section header p { margin: 0; color: var(--muted); line-height: 1.6; }

  .released-grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    border-top: 3px solid var(--ink);
    border-left: 3px solid var(--ink);
  }

  .released-grid a {
    display: grid;
    min-height: 150px;
    padding: 18px;
    color: var(--ink);
    background: var(--paper-bright);
    border-right: 3px solid var(--ink);
    border-bottom: 3px solid var(--ink);
    text-decoration: none;
  }

  .released-grid a:hover,
  .released-grid a:focus-visible { background: var(--acid); }

  .released-grid span,
  .released-grid small { font-size: 0.66rem; font-weight: 850; letter-spacing: 0.1em; text-transform: uppercase; }

  .released-grid strong { align-self: center; font-family: "Bodoni Moda Variable", Georgia, serif; font-size: 1.65rem; line-height: 0.95; }

  .released-grid small { align-self: end; }

  .method-grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 22px;
    margin-top: 44px;
  }

  .method-grid article {
    display: flex;
    min-width: 0;
    padding: 26px;
    border: 3px solid var(--ink);
    background: var(--paper-bright);
    flex-direction: column;
  }

  .method-grid article > span { color: var(--coral); font-size: 0.72rem; font-weight: 850; }

  .method-grid h2 {
    min-height: 2em;
    margin: 18px 0;
    font-family: "Bodoni Moda Variable", Georgia, serif;
    font-size: 2.3rem;
    letter-spacing: -0.04em;
    line-height: 0.95;
  }

  .method-grid p { min-height: 7em; color: var(--muted); line-height: 1.55; }

  .install-command {
    display: grid;
    gap: 12px;
    margin-top: auto;
  }

  .install-command code {
    min-height: 92px;
    padding: 12px;
    overflow-wrap: anywhere;
    border: 2px solid var(--ink);
    background: var(--paper);
    font-size: 0.68rem;
    line-height: 1.5;
  }

  @media (max-width: 1050px) {
    .released-grid { grid-template-columns: repeat(3, 1fr); }
    .method-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 650px) {
    .released-section > header { grid-template-columns: 1fr; }
    .released-grid { grid-template-columns: 1fr; }
    .gate-card { grid-template-columns: 1fr; }
    .gate-card > span { min-height: 170px; border-right: 0; border-bottom: 3px solid var(--ink); }
    .method-grid { grid-template-columns: 1fr; }
  }
</style>
